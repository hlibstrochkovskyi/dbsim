# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/

# Virtual envs / uv
.venv/
uv.lock.*

# Test / type / coverage caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml

# Data — large, downloaded, regenerable. Never committed (see docs/data-versioning.md).
# Raw/processed bytes stay out of git; only the small source.json manifests are kept,
# so every dataset stays reproducible (source + date + sha256) without storing it.
data/raw/**
data/processed/**
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/raw/**/
!data/raw/**/source.json

# Recordings (sim outputs)
*.parquet
*.duckdb

# Notebook checkpoints
.ipynb_checkpoints/

# OS / editor
.DS_Store
.idea/
.vscode/
